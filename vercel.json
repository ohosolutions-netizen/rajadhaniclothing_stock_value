{
  "version": 2,
  "builds": [
    {
      "src": "api/stock-statement.js",
      "use": "@vercel/node"
    },
    {
      "src": "app/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/stock-statement",
      "dest": "/api/stock-statement.js"
    },
    {
      "src": "/",
      "dest": "/app/index.html"
    },
    {
      "src": "/app/?",
      "dest": "/app/index.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/app/$1"
    }
  ]
}
